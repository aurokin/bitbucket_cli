.SH NAME
bb-api - Make an authenticated Bitbucket API request


.SH SYNOPSIS
\fBbb api  [flags]\fP


.SH DESCRIPTION
Make an authenticated Bitbucket Cloud API request. Use this for workflows that are not yet covered by a dedicated bb command.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for api

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--input\fP=""
	Read request body from a file, or '-' for stdin

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB-X\fP, \fB--method\fP="GET"
	HTTP method


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb api /user
  bb api '/repositories/workspace-slug/repo-slug/pullrequests?state=OPEN'
  bb api /user --jq .display_name
  printf '{"name":"my-repo"}' | bb api /repositories/workspace-slug/my-repo -X POST --input -
.EE


