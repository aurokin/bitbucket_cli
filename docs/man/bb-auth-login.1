.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-auth-login - Store credentials for a Bitbucket host


.SH SYNOPSIS
\fBbb auth login [flags]\fP


.SH DESCRIPTION
Store an Atlassian API token for Bitbucket Cloud. The username should be your Atlassian account email. Humans can run \fBbb auth login\fR interactively and paste the token securely. Agents can provide \fBBB_EMAIL\fR and \fBBB_TOKEN\fR, or pass \fB--username\fR and \fB--token\fR explicitly.


.SH OPTIONS
\fB--default\fP[=true]
	Set this host as the default

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for login

.PP
\fB--host\fP="bitbucket.org"
	Bitbucket host to configure

.PP
\fB--token\fP=""
	Atlassian API token to store

.PP
\fB--username\fP=""
	Atlassian account email associated with the API token

.PP
\fB--with-token\fP[=false]
	Read the API token from stdin


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb auth login --username you@example.com --with-token
  bb auth login --username you@example.com --token $BITBUCKET_TOKEN
  BB_EMAIL=you@example.com BB_TOKEN=$BITBUCKET_TOKEN bb auth login
  printf '%s\\n' "$BITBUCKET_TOKEN" | bb auth login --username you@example.com --with-token
.EE


.SH SEE ALSO
\fBbb-auth(1)\fP


