.SH NAME
bb-branch-create - Create a branch


.SH SYNOPSIS
\fBbb branch create  [flags]\fP


.SH DESCRIPTION
Create a Bitbucket branch from one commit hash or branch name. When run inside a matching checkout, bb defaults the target to the current branch if --target is omitted.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for create

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--target\fP=""
	Source commit hash or branch name to branch from

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb branch create feature/demo --repo workspace-slug/repo-slug --target main
  bb branch create feature/demo --repo workspace-slug/repo-slug --target abc1234 --json '*'

.EE


