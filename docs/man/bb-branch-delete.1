.SH NAME
bb-branch-delete - Delete a branch


.SH SYNOPSIS
\fBbb branch delete  [flags]\fP


.SH DESCRIPTION
Delete a Bitbucket branch. Humans must confirm the exact repository and branch unless --yes is provided. Scripts and agents should use --yes together with --no-prompt.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for delete

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target

.PP
\fB--yes\fP[=false]
	Skip the confirmation prompt


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb branch delete feature/demo --repo workspace-slug/repo-slug --yes
  bb --no-prompt branch delete feature/demo --repo workspace-slug/repo-slug --yes --json '*'

.EE


.SH SEE ALSO
\fBbb-branch(1)\fP


