.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-browse - Open or print Bitbucket web URLs


.SH SYNOPSIS
\fBbb browse [target] [flags]\fP


.SH DESCRIPTION
Open Bitbucket repository, pull request, issue, commit, settings, pipelines, and source URLs. Default behavior opens the browser; use --no-browser to print the URL instead.


.SH OPTIONS
\fB--branch\fP=""
	Branch name for source browsing

.PP
\fB--commit\fP=""
	Commit SHA for source browsing

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for browse

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--issue\fP=0
	Open one issue by ID

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--no-browser\fP[=false]
	Print the destination URL instead of opening the browser

.PP
\fB--pipelines\fP[=false]
	Open repository pipelines

.PP
\fB--pr\fP=0
	Open one pull request by ID

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--settings\fP[=false]
	Open repository settings

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb browse --repo workspace-slug/repo-slug
  bb browse README.md:12 --repo workspace-slug/repo-slug --no-browser
  bb browse --pr 1 --repo workspace-slug/repo-slug
  bb browse --pipelines --repo workspace-slug/repo-slug --json '*'
  bb browse a1b2c3d --repo workspace-slug/repo-slug --no-browser
.EE


.SH SEE ALSO
\fBbb(1)\fP


