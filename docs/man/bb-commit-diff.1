.SH NAME
bb-commit-diff - Show a commit diff


.SH SYNOPSIS
\fBbb commit diff  [flags]\fP


.SH DESCRIPTION
Show a commit patch by default or diff stats with --stat. Accepts a commit SHA or a commit URL.


.SH OPTIONS
\fB--binary\fP[=true]
	Include binary file changes in the raw diff

.PP
\fB--context\fP=0
	Lines of context to include in the raw diff

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for diff

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--ignore-whitespace\fP[=false]
	Ignore whitespace changes in the raw diff

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--path\fP=[]
	Limit the raw diff to one or more file paths

.PP
\fB--renames\fP[=true]
	Perform rename detection in the raw diff

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--stat\fP[=false]
	Show per-file diff stats instead of the raw patch

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb commit diff abc1234 --repo workspace-slug/repo-slug
  bb commit diff abc1234 --repo workspace-slug/repo-slug --stat
  bb commit diff https://bitbucket.org/workspace-slug/repo-slug/commits/abc1234 --json patch,stats
.EE


