.SH NAME
bb-commit-statuses - List commit statuses for a commit


.SH SYNOPSIS
\fBbb commit statuses  [flags]\fP


.SH DESCRIPTION
List Bitbucket commit statuses for a commit. Accepts a commit SHA or a commit URL.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for statuses

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=20
	Maximum number of commit statuses to return

.PP
\fB--query\fP=""
	Bitbucket commit status query filter

.PP
\fB--refname\fP=""
	Limit statuses to the given ref name

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--sort\fP="-created_on"
	Bitbucket commit status sort expression

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb commit statuses abc1234 --repo workspace-slug/repo-slug
  bb commit checks https://bitbucket.org/workspace-slug/repo-slug/commits/abc1234 --json statuses
  bb commit statuses abc1234 --repo workspace-slug/repo-slug --limit 50
.EE


