.SH NAME
bb-deployment-environment-variable-create - Create a deployment environment variable


.SH SYNOPSIS
\fBbb deployment environment variable create [flags]\fP


.SH DESCRIPTION
Create a deployment environment variable


.SH OPTIONS
\fB--environment\fP=""
	Deployment environment reference as a name, slug, or UUID

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for create

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--key\fP=""
	Deployment variable key

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--secured\fP[=false]
	Mark the deployment variable as secured

.PP
\fB--value\fP=""
	Deployment variable value

.PP
\fB--value-file\fP=""
	Read the deployment variable value from a file, or '-' for stdin

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb deployment environment variable create --repo workspace-slug/pipelines-repo-slug --environment test --key APP_ENV --value production
  bb deployment environment variable create --repo workspace-slug/pipelines-repo-slug --environment test --key SECRET_TOKEN --value-file secret.txt --secured
  printf 'secret\\n' | bb deployment environment variable create --repo workspace-slug/pipelines-repo-slug --environment test --key SECRET_TOKEN --value-file - --json '*'
.EE


