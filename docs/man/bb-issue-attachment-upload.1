.SH NAME
bb-issue-attachment-upload - Upload attachments to an issue


.SH SYNOPSIS
\fBbb issue attachment upload  \&... [flags]\fP


.SH DESCRIPTION
Upload one or more files to a Bitbucket issue. Existing attachments with the same name are replaced by Bitbucket Cloud.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for upload

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb issue attachment upload 1 ./trace.txt --repo workspace-slug/issues-repo-slug
  bb issue attachment upload https://bitbucket.org/workspace-slug/issues-repo-slug/issues/1 ./trace.txt ./screenshot.png --json '*'
.EE


.SH SEE ALSO
\fBbb-issue-attachment(1)\fP


