.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-pipeline-run - Trigger a pipeline run


.SH SYNOPSIS
\fBbb pipeline run [ref] [flags]\fP


.SH DESCRIPTION
Trigger a Bitbucket pipeline run for a branch or tag. If no ref is provided, bb uses the current local branch when the repository target matches the current checkout.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for run

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--ref\fP=""
	Branch or tag name to build

.PP
\fB--ref-type\fP="branch"
	Reference type to build: branch or tag

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pipeline run main --repo workspace-slug/pipelines-repo-slug
  bb pipeline run --repo workspace-slug/pipelines-repo-slug --ref main --json '*'
  bb pipeline run v1.2.3 --ref-type tag --repo workspace-slug/pipelines-repo-slug
.EE


.SH SEE ALSO
\fBbb-pipeline(1)\fP


