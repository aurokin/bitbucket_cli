.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-pipeline-schedule-create - Create a pipeline schedule


.SH SYNOPSIS
\fBbb pipeline schedule create [flags]\fP


.SH DESCRIPTION
Create a Bitbucket pipeline schedule for a branch. By default bb uses the branch name as the selector pattern and the branches selector type.


.SH OPTIONS
\fB--cron\fP=""
	Seven-field cron pattern in UTC

.PP
\fB--enabled\fP[=true]
	Create the schedule enabled

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for create

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--ref\fP=""
	Branch name to run on the schedule

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--selector-pattern\fP=""
	Pipeline selector pattern; defaults to the ref name

.PP
\fB--selector-type\fP=""
	Pipeline selector type, for example branches or custom

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pipeline schedule create --repo workspace-slug/pipelines-repo-slug --ref main --cron '0 0 12 * * ? *'
  bb pipeline schedule create --repo workspace-slug/pipelines-repo-slug --ref release --cron '0 30 9 * * ? *' --enabled=false --json '*'
  bb pipeline schedule create --repo workspace-slug/pipelines-repo-slug --ref main --selector-type custom --selector-pattern nightly --cron '0 0 1 * * ? *'
.EE


