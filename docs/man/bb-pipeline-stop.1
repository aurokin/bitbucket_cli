.SH NAME
bb-pipeline-stop - Stop a running pipeline


.SH SYNOPSIS
\fBbb pipeline stop  [flags]\fP


.SH DESCRIPTION
Stop a Bitbucket pipeline run. Humans must confirm the exact repository and pipeline number unless --yes is provided. Scripts and agents should use --yes together with --no-prompt.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for stop

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target

.PP
\fB--yes\fP[=false]
	Skip the confirmation prompt


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pipeline stop 42 --repo workspace-slug/pipelines-repo-slug --yes
  bb pipeline stop '{uuid}' --repo workspace-slug/pipelines-repo-slug --json '*'
  bb --no-prompt pipeline stop 42 --repo workspace-slug/pipelines-repo-slug --yes --json pipeline,stopped
.EE


