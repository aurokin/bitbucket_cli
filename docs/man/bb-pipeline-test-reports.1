.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-pipeline-test-reports - View pipeline test reports


.SH SYNOPSIS
\fBbb pipeline test-reports  [flags]\fP


.SH DESCRIPTION
View Bitbucket pipeline test reports for one pipeline step. If the pipeline has exactly one step, bb selects it automatically. Otherwise pass --step with a step UUID or step name.


.SH OPTIONS
\fB--cases\fP[=false]
	Include individual test cases in the response

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for test-reports

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=20
	Maximum number of test cases to return when --cases is set

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--step\fP=""
	Pipeline step UUID or name when a pipeline has more than one step

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pipeline test-reports 42 --repo workspace-slug/pipelines-repo-slug
  bb pipeline test-reports 42 --repo workspace-slug/pipelines-repo-slug --cases --limit 50 --json '*'
  bb pipeline test-reports '{uuid}' --repo workspace-slug/pipelines-repo-slug --step '{step-uuid}'
.EE


