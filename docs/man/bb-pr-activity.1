.SH NAME
bb-pr-activity - Show recent pull request activity


.SH SYNOPSIS
\fBbb pr activity  [flags]\fP


.SH DESCRIPTION
Show recent pull request activity including comments, updates, approvals, and change requests. Accepts a numeric ID, pull request URL, or pull request comment URL.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for activity

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=20
	Maximum number of activity entries to return

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pr activity 7 --repo workspace-slug/repo-slug
  bb pr activity https://bitbucket.org/workspace-slug/repo-slug/pull-requests/7 --limit 50 --json '*'
  bb pr activity https://bitbucket.org/workspace-slug/repo-slug/pull-requests/7#comment-15
.EE


