.SH NAME
bb-pr-commits - List commits on a pull request


.SH SYNOPSIS
\fBbb pr commits  [flags]\fP


.SH DESCRIPTION
List the commits that would be merged by the pull request. Accepts a numeric ID, pull request URL, or pull request comment URL.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for commits

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=20
	Maximum number of commits to return

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pr commits 7 --repo workspace-slug/repo-slug
  bb pr commits https://bitbucket.org/workspace-slug/repo-slug/pull-requests/7 --json '*'
  bb pr commits https://bitbucket.org/workspace-slug/repo-slug/pull-requests/7#comment-15 --limit 50
.EE


