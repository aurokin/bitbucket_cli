.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-pr-create - Create a pull request


.SH SYNOPSIS
\fBbb pr create [flags]\fP


.SH DESCRIPTION
Create a pull request in Bitbucket Cloud. When run interactively, bb prompts for missing fields. The source branch defaults to the current branch and the destination defaults to the repository main branch.


.SH OPTIONS
\fB--close-source-branch\fP[=false]
	Close the source branch when the pull request is merged

.PP
\fB--description\fP=""
	Pull request description

.PP
\fB--destination\fP=""
	Destination branch; defaults to the repository main branch

.PP
\fB--draft\fP[=false]
	Create the pull request as a draft

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for create

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--reuse-existing\fP[=false]
	Return an existing matching open pull request instead of creating a new one

.PP
\fB--source\fP=""
	Source branch; defaults to the current git branch

.PP
\fB--title\fP=""
	Pull request title; defaults to the source branch name

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pr create --title 'Add feature'
  bb pr create --source feature --destination main --description 'Ready for review'
  bb pr create --reuse-existing --json
.EE


.SH SEE ALSO
\fBbb-pr(1)\fP


