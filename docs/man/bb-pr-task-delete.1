.SH NAME
bb-pr-task-delete - Delete a pull request task


.SH SYNOPSIS
\fBbb pr task delete  [flags]\fP


.SH DESCRIPTION
Delete a Bitbucket pull request task. Humans must confirm the exact repository, pull request, and task unless --yes is provided. Scripts and agents should use --yes together with --no-prompt.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for delete

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--pr\fP=""
	Parent pull request as an ID or Bitbucket pull request URL

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target

.PP
\fB--yes\fP[=false]
	Skip the confirmation prompt


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb pr task delete 3 --pr 1 --repo workspace-slug/repo-slug --yes
  bb --no-prompt pr task delete 3 --pr https://bitbucket.org/workspace-slug/repo-slug/pull-requests/1 --yes --json '*'
.EE


.SH SEE ALSO
\fBbb-pr-task(1)\fP


