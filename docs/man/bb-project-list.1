.SH NAME
bb-project-list - List projects in a workspace


.SH SYNOPSIS
\fBbb project list [workspace] [flags]\fP


.SH DESCRIPTION
List Bitbucket projects in one workspace. If you have access to exactly one workspace, the workspace can be omitted.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=20
	Maximum number of projects to return

.PP
\fB--workspace\fP=""
	Workspace slug to inspect


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb project list workspace-slug
  bb project list --workspace workspace-slug --limit 50
  bb project list workspace-slug --json projects
.EE


