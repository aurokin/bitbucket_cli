.SH NAME
bb-repo-clone - Clone a Bitbucket repository locally


.SH SYNOPSIS
\fBbb repo clone [repository] [directory] [flags]\fP


.SH DESCRIPTION
Clone a Bitbucket repository over HTTPS using the configured API token. Prefer --repo / for explicit targeting; use --workspace only to disambiguate a bare repository name. The origin remote is rewritten after cloning so the token is not stored in git config.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for clone

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb repo clone workspace-slug/repo-slug
  bb repo clone --repo workspace-slug/repo-slug ./tmp/repo
  bb repo clone repo-slug --workspace workspace-slug
  bb repo clone https://bitbucket.org/workspace-slug/repo-slug
  bb repo clone workspace-slug/repo-slug ./tmp/repo --json
.EE


