.SH NAME
bb-repo-create - Create a repository in Bitbucket Cloud


.SH SYNOPSIS
\fBbb repo create [repository] [flags]\fP


.SH DESCRIPTION
Create a repository in Bitbucket Cloud. Prefer --repo / for explicit targeting; use --workspace only to disambiguate a bare repository name. Use --reuse-existing when the command may be run repeatedly.


.SH OPTIONS
\fB--description\fP=""
	Repository description

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for create

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--name\fP=""
	Display name for the repository

.PP
\fB--private\fP[=true]
	Create the repository as private

.PP
\fB--project-key\fP=""
	Bitbucket project key for the repository

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--reuse-existing\fP[=false]
	Return the existing repository instead of failing when it already exists

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb repo create workspace-slug/my-repo --project-key BBCLI
  bb repo create --repo workspace-slug/my-repo --reuse-existing --json
  bb repo create my-repo --workspace workspace-slug
.EE


