.SH NAME
bb-repo-edit - Edit repository metadata


.SH SYNOPSIS
\fBbb repo edit [repository] [flags]\fP


.SH DESCRIPTION
Edit a Bitbucket repository's name, description, or visibility. Use --repo / for deterministic targeting.


.SH OPTIONS
\fB--description\fP=""
	New repository description

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for edit

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--name\fP=""
	New repository display name

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--visibility\fP=""
	New repository visibility: private or public

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb repo edit workspace-slug/repo-slug --description 'Updated description'
  bb repo edit --repo workspace-slug/repo-slug --visibility public --json '*'
  bb repo edit repo-slug --workspace workspace-slug --name 'Renamed repo'
.EE


