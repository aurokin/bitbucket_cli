.TH "BB" "1" "Mar 2026" "bb" "Bitbucket CLI"

.SH NAME
bb-repo-fork - Fork a repository


.SH SYNOPSIS
\fBbb repo fork [repository] [flags]\fP


.SH DESCRIPTION
Fork a Bitbucket repository. When forking into the same workspace, Bitbucket requires a new fork name because the slug is derived from the name.


.SH OPTIONS
\fB--description\fP=""
	Fork description override

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for fork

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--name\fP=""
	Fork display name; required when forking into the same workspace

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--reuse-existing\fP[=false]
	Return an existing matching fork instead of failing

.PP
\fB--to-workspace\fP=""
	Workspace to create the fork in; defaults to the source workspace

.PP
\fB--visibility\fP=""
	Fork visibility override: private or public

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb repo fork workspace-slug/repo-slug --to-workspace workspace-slug --name repo-slug-fork
  bb repo fork --repo workspace-slug/repo-slug --to-workspace other-workspace --reuse-existing --json '*'
  bb repo fork repo-slug --workspace workspace-slug --to-workspace workspace-slug --name repo-slug-fork
.EE


