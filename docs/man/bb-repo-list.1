.SH NAME
bb-repo-list - List repositories in a workspace


.SH SYNOPSIS
\fBbb repo list [workspace] [flags]\fP


.SH DESCRIPTION
List Bitbucket repositories in one workspace. If you have access to exactly one workspace, the workspace can be omitted.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=20
	Maximum number of repositories to return

.PP
\fB--query\fP=""
	Bitbucket repository query filter

.PP
\fB--sort\fP="-updated_on"
	Bitbucket repository sort expression

.PP
\fB--workspace\fP=""
	Workspace slug to list repositories from


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb repo list workspace-slug
  bb repo list --workspace workspace-slug --limit 50
  bb repo list workspace-slug --query 'name ~ "bb"' --json repos
.EE


