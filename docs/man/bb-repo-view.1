.SH NAME
bb-repo-view - Show repository information


.SH SYNOPSIS
\fBbb repo view [flags]\fP


.SH DESCRIPTION
Show repository information from Bitbucket Cloud. When run inside a git checkout, local remote details are included in the output.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for view

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb repo view
  bb repo view --repo workspace-slug/repo-slug
  bb repo view --repo https://bitbucket.org/workspace-slug/repo-slug
  bb repo view --json name,project_key,main_branch
.EE


