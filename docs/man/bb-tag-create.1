.SH NAME
bb-tag-create - Create a tag


.SH SYNOPSIS
\fBbb tag create  [flags]\fP


.SH DESCRIPTION
Create a Bitbucket tag from one commit hash or branch name. When run inside a matching checkout, bb defaults the target to the current branch if --target is omitted.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for create

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--message\fP=""
	Optional tag message for annotated tags

.PP
\fB--repo\fP=""
	Bitbucket repository target as , /, or a repository URL

.PP
\fB--target\fP=""
	Source commit hash or branch name to tag

.PP
\fB--workspace\fP=""
	Optional workspace slug used only to disambiguate a bare repository target


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb tag create v1.0.0 --repo workspace-slug/repo-slug --target main --message 'release'
  bb tag create v1.0.0 --repo workspace-slug/repo-slug --target abc1234 --json '*'

.EE


