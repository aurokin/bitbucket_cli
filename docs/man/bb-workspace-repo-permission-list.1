.SH NAME
bb-workspace-repo-permission-list - List effective repository permissions in a workspace


.SH SYNOPSIS
\fBbb workspace repo-permission list [workspace] [flags]\fP


.SH DESCRIPTION
List effective repository permissions across a workspace or for one repository within a workspace. Bitbucket only exposes list endpoints for this surface.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--host\fP=""
	Bitbucket host to use

.PP
\fB--jq\fP=""
	Filter JSON output using a jq expression

.PP
\fB--json\fP[=""]
	Output JSON with the specified comma-separated fields, or '*' for all fields

.PP
\fB--limit\fP=50
	Maximum number of workspace repository permissions to return

.PP
\fB--query\fP=""
	Bitbucket workspace repository permission query filter

.PP
\fB--repo\fP=""
	Optional repository filter as , /, or a repository URL

.PP
\fB--sort\fP=""
	Bitbucket workspace repository permission sort expression

.PP
\fB--workspace\fP=""
	Workspace slug to inspect


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--no-prompt\fP[=false]
	Do not prompt for missing input, even in an interactive terminal


.SH EXAMPLE
.EX
  bb workspace repo-permission list workspace-slug
  bb workspace repo-permission list workspace-slug --repo repo-slug
  bb workspace repo-permission list --workspace workspace-slug --repo workspace-slug/repo-slug --json permissions
.EE


